{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "enabled": true,
    "managerFilePatterns": [
      "/^kubernetes\\/apps\\/addons\\/argocd-apps\\/application\\.ya?ml$/",
      "/^kubernetes\\/apps\\/addons\\/argocd-apps\\/templates\\/.+\\.ya?ml$/"
    ]
  },
  "helmv3": {
    "enabled": true,
    "managerFilePatterns": ["/(^|/)Chart\\.ya?ml$/"]
  },
  "helm-values": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)values\\.ya?ml$/",
      "/(^|/)values\\.sops\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "enabled": true,
    "managerFilePatterns": ["/^kubernetes\\/.+\\.ya?ml$/"]
  },
  "terraform": {
    "enabled": true,
    "managerFilePatterns": ["/^terraform\\/.+\\.tf$/"]
  },
  "ignorePaths": ["**/.decrypted~*.yaml"],
  "packageRules": [
    {
      "description": "Ignore git SSH URL picked up natively by ansible manager — handled by custom manager",
      "matchPackageNames": ["git@github.com:k3s-io/k3s-ansible.git"],
      "enabled": false
    },
    {
      "description": "Do not update image tags pinned to latest",
      "matchDatasources": ["docker"],
      "matchCurrentValue": "/^latest$/",
      "enabled": false
    },
    {
      "description": "Preserve range constraints for Helm charts in ArgoCD",
      "matchManagers": ["argocd"],
      "matchDepTypes": ["helm"],
      "rangeStrategy": "widen"
    },
    {
      "description": "Avoid updating encrypted blobs in SOPS files",
      "matchFileNames": ["**/*.sops.yaml"],
      "matchCurrentValue": "/^ENC\\[/",
      "enabled": false
    },
    {
      "description": "Group ArgoCD app-of-apps minor/patch updates",
      "matchManagers": ["argocd"],
      "matchFileNames": ["kubernetes/apps/addons/argocd-apps/**"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "argocd app definitions"
    },
    {
      "description": "Group Helm chart dependency minor/patch updates",
      "matchManagers": ["helmv3"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "helm chart dependencies"
    },
    {
      "description": "Group Helm values image minor/patch updates",
      "matchManagers": ["helm-values"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "helm values images"
    },
    {
      "description": "Group Terraform provider minor/patch updates",
      "matchManagers": ["terraform"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "terraform providers"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update helm-secrets version in ArgoCD init container",
      "managerFilePatterns": ["/^kubernetes\\/apps\\/addons\\/argocd\\/values\\.sops\\.ya?ml$/"],
      "matchStrings": ["- name: HELM_SECRETS_VERSION\\s+value: (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "jkroepke/helm-secrets",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update sops version in ArgoCD init container",
      "managerFilePatterns": ["/^kubernetes\\/apps\\/addons\\/argocd\\/values\\.sops\\.ya?ml$/"],
      "matchStrings": ["- name: SOPS_VERSION\\s+value: (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "getsops/sops",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update vals version in ArgoCD init container",
      "managerFilePatterns": ["/^kubernetes\\/apps\\/addons\\/argocd\\/values\\.sops\\.ya?ml$/"],
      "matchStrings": ["- name: VALS_VERSION\\s+value: (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "helmfile/vals",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update kubectl version in ArgoCD init container",
      "managerFilePatterns": ["/^kubernetes\\/apps\\/addons\\/argocd\\/values\\.sops\\.ya?ml$/"],
      "matchStrings": ["- name: KUBECTL_VERSION\\s+value: (?<currentValue>[^\\n]+)"],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update k3s version in Ansible group vars",
      "managerFilePatterns": [
        "/^ansible\\/inventory\\/group_vars\\/k3s_cluster\\.sops\\.ya?ml$/"
      ],
      "matchStrings": [
        "k3s_version:\\s+(?<currentValue>[^\\n]+)"
      ],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update k3s-ansible git collection in Ansible requirements",
      "managerFilePatterns": ["/^ansible\\/requirements\\.ya?ml$/"],
      "matchStrings": [
        "name: git@github\\.com:k3s-io/k3s-ansible\\.git\\s+type: git\\s+version: \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "k3s-io/k3s-ansible",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update Tailscale version in Ansible group vars",
      "managerFilePatterns": [
        "/^ansible\\/inventory\\/group_vars\\/all\\.sops\\.ya?ml$/"
      ],
      "matchStrings": [
        "tailscale_version:\\s+(?<currentValue>[^\\n]+)"
      ],
      "depNameTemplate": "tailscale/tailscale",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
